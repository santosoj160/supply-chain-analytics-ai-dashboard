      <column caption='Latest Forecast' datatype='boolean' name='[Calculation_0605559193317376]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[ds] = { MAX([ds]) }' />
      </column>
      <column caption='Last Row Only' datatype='boolean' name='[Calculation_0605559200174086]' role='measure' type='nominal'>
        <calculation class='tableau' formula='LAST() = 0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Latest Forecast Growth' datatype='real' name='[Calculation_0605559200710663]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;WINDOW_MAX(SUM([yhat]))&#13;&#10;-&#13;&#10;LOOKUP(WINDOW_MAX(SUM([yhat])), -1)&#13;&#10;)&#13;&#10;/&#13;&#10;LOOKUP(WINDOW_MAX(SUM([yhat])), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Forecast Type' datatype='string' name='[Calculation_0605559226318860]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ds] &lt;= TODAY() THEN&#13;&#10;&quot;Historical&quot;&#13;&#10;ELSE&#13;&#10;&quot;Forecast&quot;&#13;&#10;END' />
      </column>
      <column caption='Forecast Growth %' datatype='real' name='[Calculation_3222396839981072]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([yhat]) - LOOKUP(SUM([yhat]), -1)&#13;&#10;)&#13;&#10;/&#13;&#10;LOOKUP(SUM([yhat]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
