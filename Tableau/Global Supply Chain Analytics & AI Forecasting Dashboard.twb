            <column-instance column='[Calculation_0605559200174086]' derivation='User' name='[usr:Calculation_0605559200174086:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Rows' />
            </column-instance>
            <column-instance column='[Calculation_3222396839981072]' derivation='User' name='[usr:Calculation_3222396839981072:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
            </column-instance>
            <column caption='Yhat' datatype='real' name='[yhat]' role='measure' type='quantitative' />
            <column-instance column='[ds]' derivation='Year' name='[yr:ds:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
